{
  "version": "1.4.1",
  "name": "Danny's Tracker",
  "identifier": "danny_tracker",
  "author": "dantalionsama",
  "github": "https://github.com/dantalionsama/danny_tracker",
  "homepage": "https://github.com/dantalionsama/danny_tracker",
  "description": "Floating widget tracking scene state and multiple characters. Auto-updates from hidden AI tags, per-chat state, mood color theming.",
  "permissions": [
    "ephemeral_storage",
    "ui_panels",
    "chats"
  ],
  "entry_backend": "dist/backend.js",
  "entry_frontend": "dist/frontend.js",
  "storage_seed_files": [
    {
      "from": "storage/danny_tracker",
      "to": ".",
      "overwrite": false,
      "required": false
    }
  ],
  "minimum_lumiverse_version": "0.9.0"
}
